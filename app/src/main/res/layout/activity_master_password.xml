<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/matrix_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_master_password"
        android:textColor="@color/matrix_green"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editMasterPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/code_cell_bg"
        android:hint="@string/settings_master_password_hint"
        android:inputType="number"
        android:digits="0123456789"
        android:maxLength="6"
        android:padding="12dp"
        android:textColor="@color/code_cell_text"
        android:textColorHint="#8000FF41"/>

    <Button
        android:id="@+id/btnSaveMaster"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_save"
        android:textColor="@color/matrix_green"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/matrix_green"/>

    <Button
        android:id="@+id/btnBackMaster"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/close"
        android:textColor="@color/code_cell_text"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
</LinearLayout>
